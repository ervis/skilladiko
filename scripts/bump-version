#!/bin/bash

# Bump version using semantic versioning via git tags
# Usage: ./scripts/bump-version [major|minor|patch] [OPTIONS]
# Default: patch
# Examples:
#   ./scripts/bump-version              # Bump patch
#   ./scripts/bump-version minor        # Bump minor
#   ./scripts/bump-version major --push # Bump major and push tag
#   ./scripts/bump-version --show       # Show current version

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Parse arguments
BUMP_TYPE="patch"
SHOULD_PUSH=false
SHOW_ONLY=false
# Check for special flags first
for arg in "$@"; do
  case $arg in
    --help|-h)
      echo "Bump version using semantic versioning"
      echo ""
      echo "Usage: $0 [major|minor|patch] [OPTIONS]"
      echo ""
      echo "Bump type (default: patch):"
      echo "  major          Bump major version (X.0.0)"
      echo "  minor          Bump minor version (0.X.0)"
      echo "  patch          Bump patch version (0.0.X)"
      echo ""
      echo "Options:"
      echo "  --push         Push tag to origin after creating"
      echo "  --show         Show current version and exit"
      echo "  --help, -h     Show this help message"
      echo ""
      echo "Examples:"
      echo "  $0                       # Bump patch"
      echo "  $0 minor                 # Bump minor"
      echo "  $0 major --push          # Bump major and push"
      echo "  $0 --show                # Show current version"
      exit 0
      ;;
    --show)
      SHOW_ONLY=true
      ;;
    --push)
      SHOULD_PUSH=true
      ;;
    major|minor|patch)
      BUMP_TYPE=$arg
      ;;
  esac
done

# Get latest tag
LATEST_TAG=$(git tag --sort=-version:refname --merged HEAD | head -n 1)

if [ -z "$LATEST_TAG" ]; then
  if [ "$SHOW_ONLY" = false ]; then
    echo -e "${YELLOW}No existing tags found.${NC}"
  fi
  NEW_TAG="v0.1.0"
else
  echo -e "${YELLOW}Current version: ${BLUE}$LATEST_TAG${NC}"

  # If --show only, exit here
  if [ "$SHOW_ONLY" = true ]; then
    exit 0
  fi

  # Parse version (expecting v1.2.3 format)
  VERSION="${LATEST_TAG#v}"
  IFS='.' read -r MAJOR MINOR PATCH <<< "$VERSION"

  # Validate version format
  if ! [[ "$MAJOR" =~ ^[0-9]+$ ]] || ! [[ "$MINOR" =~ ^[0-9]+$ ]] || ! [[ "$PATCH" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Latest tag '$LATEST_TAG' is not in valid semver format (v1.2.3)${NC}"
    exit 1
  fi

  # Bump version
  case $BUMP_TYPE in
    major)
      MAJOR=$((MAJOR + 1))
      MINOR=0
      PATCH=0
      ;;
    minor)
      MINOR=$((MINOR + 1))
      PATCH=0
      ;;
    patch)
      PATCH=$((PATCH + 1))
      ;;
  esac

  NEW_TAG="v${MAJOR}.${MINOR}.${PATCH}"
fi

echo -e "${GREEN}New version: ${BLUE}$NEW_TAG${NC}"

# Create tag
git tag "$NEW_TAG"
echo -e "${GREEN}✓ Created tag: $NEW_TAG${NC}"

# Push if requested
if [ "$SHOULD_PUSH" = true ]; then
  git push origin "$NEW_TAG"
  echo -e "${GREEN}✓ Pushed tag: $NEW_TAG${NC}"
else
  echo -e "${YELLOW}ℹ Tag created but not pushed. Run: ${BLUE}git push origin $NEW_TAG${NC}"
fi

echo -e "${GREEN}Done!${NC}"
